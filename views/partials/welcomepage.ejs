<div class="welcome-container">
  <!-- AI callout card -->
  <div class="welcome-ai-card" onclick="toggleChat()">
    <div class="welcome-ai-title"><span class="welcome-ai-icon">&#9413;</span> Not sure where to start?</div>
    <p class="welcome-ai-desc">Chat with our <strong style="color:#EE7F2D;">all-new AI assistant</strong> about
      everything from <span style="color:#EE7F2D;">TigerSnatch trends, major requirements</span> to your <span
        style="color:#EE7F2D;">TigerJunction schedules,</span> and much, much more!</p>
  </div>

  <!-- Decorative arc -->
  <div class="welcome-arc"></div>

  <!-- Welcome text + Calvin image -->
  <div class="welcome-hero">
    <h2 class="welcome-title">
      <span>W</span><span>E</span><span>L</span><span>C</span><span>O</span><span>M</span><span>E</span><span>!</span>
    </h2>
    <div class="welcome-img-wrap">
      <img src="../media/calvin_logo.gif" class="img-responsive center-block welcome-img" alt="Calvin and Hobbes">
      <div class="welcome-img-shadow"></div>
    </div>
  </div>

  <!-- Feature cards -->
  <div class="welcome-cards">
    <div class="welcome-card-item">
      <i class="fa fa-search welcome-card-icon"></i>
      <h4>Smart Search</h4>
      <p>Search by course name, department, PDF options, distributions, or professor.</p>
    </div>
    <div class="welcome-card-item">
      <i class="fa fa-heart welcome-card-icon"></i>
      <h4>Favorite Courses</h4>
      <p>Save courses to your Favorites list for fast access in the future.</p>
    </div>
    <div class="welcome-card-item">
      <i class="fa fa-desktop welcome-card-icon"></i>
      <h4>Course Info</h4>
      <p>Explore ratings, evaluations, and details across different semesters.</p>
    </div>
  </div>
</div>