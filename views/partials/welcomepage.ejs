<div class="welcome-container">
  <!-- AI callout card -->
  <div class="welcome-ai-card" onclick="toggleChat()">
    <div class="welcome-ai-title"><span class="welcome-ai-icon">&#9413;</span> Not sure where to start?</div>
    <p class="welcome-ai-desc">Chat with our <strong style="color:#EE7F2D;">all-new AI assistant</strong> about everything from <span style="color:#EE7F2D;">major requirements</span> to personalized <span style="color:#EE7F2D;">course recommendations</span> and much, much more!</p>
  </div>

  <!-- Decorative arc -->
  <div class="welcome-arc"></div>

  <!-- Welcome text + Calvin image -->
  <div class="welcome-hero">
    <h2 class="welcome-title">
      <span>W</span><span>E</span><span>L</span><span>C</span><span>O</span><span>M</span><span>E</span><span>!</span>
    </h2>
    <div class="welcome-img-wrap">
      <img src="../media/calvin_logo.gif" class="img-responsive center-block welcome-img" alt="Calvin and Hobbes">
      <div class="welcome-img-shadow"></div>
    </div>
  </div>

  <!-- Feature cards -->
  <div class="row row-md-flex" style="margin: 20px 40px 30px;">
    <div class="col-xs-6 col-md-3 col-xs-welcome">
      <div class="well welcome-well text-center">
        <i class="welcome-icon fa fa-search"></i>
        <h4>Smart Search</h4>
        <p>Search for course name, department, PDF options, distributions, or professor. Click on <b>&#x25BC;</b> in the search bar for more.</p>
      </div>
    </div>
    <div class="col-xs-6 col-md-3 col-xs-welcome">
      <div class="well welcome-well text-center">
        <i class="welcome-icon fa fa-heart"></i>
        <h4>Favorite Courses</h4>
        <p>Click the heart next to a course name to save it to your Favorites list for fast access in the future.</p>
      </div>
    </div>
    <div class="col-xs-6 col-md-3 col-xs-welcome">
      <div class="well welcome-well text-center">
        <i class="welcome-icon fa fa-bolt"></i>
        <h4>Clash Detection</h4>
        <p>If courses in search results have scheduling conflicts with your favorite courses, we'll place a &#x26A0;&#xFE0F; label on it.</p>
      </div>
    </div>
    <div class="col-xs-6 col-md-3 col-xs-welcome">
      <div class="well welcome-well text-center">
        <i class="welcome-icon fa fa-desktop"></i>
        <h4>Course information</h4>
        <p>Easily explore course information, ratings and evaluations of courses and professors across different semesters.</p>
      </div>
    </div>
  </div>
</div>
